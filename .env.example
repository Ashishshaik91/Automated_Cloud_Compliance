# ============================================================
#  Cloud Compliance Platform — Environment Variables
#  COPY THIS FILE TO .env AND FILL IN YOUR VALUES
#  NEVER COMMIT .env TO VERSION CONTROL
# ============================================================

# ---- Application ----
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ---- JWT ----
# JWT_SECRET_KEY is only used during dual-verify migration (JWT_DUAL_VERIFY=true)
# Leave blank or set to a strong random string if migrating from HS256
JWT_SECRET_KEY=CHANGE_ME_SEPARATE_FROM_APP_SECRET
# RS256 is the production algorithm. HS256 fallback is only for zero-downtime migration.
JWT_ALGORITHM=RS256
# Set to true ONLY during migration period; false for all production deployments
JWT_DUAL_VERIFY=false
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=compliance_db
POSTGRES_USER=compliance_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://compliance_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/compliance_db

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ---- MinIO (Evidence Storage) ----
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET_EVIDENCE=compliance-evidence
MINIO_SECURE=false

# ---- OPA (Open Policy Agent) ----
OPA_HOST=opa
OPA_PORT=8181
# IMPORTANT: OPA runs with TLS — must use https://
OPA_URL=https://opa:8181

# ---- AWS Connector (optional) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ROLE_ARN=

# ---- Azure Connector (optional) ----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ---- GCP Connector (optional) ----
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON_PATH=

# ---- Threat Intelligence (optional) ----
# NVD — leave blank to use unauthenticated tier (50 req/30 s); set for 2000 req/day
NVD_API_KEY=

# VirusTotal v3 — free tier: 4 req/min; set to enable IP reputation enrichment
VIRUSTOTAL_API_KEY=

# MISP — set MISP_URL + MISP_API_KEY to enable MISP threat event enrichment.
# Leave both empty to disable.
MISP_URL=
MISP_API_KEY=

# MISP TLS Certificate Verification
# ─────────────────────────────────
# MISP is a self-hosted service and commonly uses self-signed or private-CA TLS certs.
# Do NOT set verify=False. Instead, provide the CA certificate that signed your MISP
# server's TLS certificate here.
#
# How to get this value:
#   Option A — Self-signed cert: export your MISP server's cert:
#     openssl s_client -connect <misp-host>:443 </dev/null 2>/dev/null | \
#       openssl x509 > misp_ca.pem
#     Place the file at: secrets/misp_ca.pem
#     Set below:  MISP_CA_CERT=/app/secrets/misp_ca.pem
#
#   Option B — Private CA: export your organisation's root CA bundle into a PEM file.
#     Place the file at: secrets/misp_ca.pem
#     Set below:  MISP_CA_CERT=/app/secrets/misp_ca.pem
#
#   Option C — Publicly CA-signed cert (Let's Encrypt, etc.):
#     Leave MISP_CA_CERT empty. The system CA store will verify the cert automatically.
#
# docker-compose: the secrets/ directory is already mounted into the backend container
# at /app/secrets — no additional volume mount is needed if you place the cert there.
MISP_CA_CERT=

# ---- Alerting Integrations ----
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@yourdomain.com

# ---- Celery ----
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2
SCAN_INTERVAL_SECONDS=300

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- Prometheus Metrics Scrape Allowlist ----
# Controls which IPs and CIDR ranges are allowed to scrape the GET /metrics endpoint.
# Non-matching source IPs receive a stealth 404 (even if they present valid admin credentials).
# Format: comma-separated list of IPv4/IPv6 addresses and CIDR ranges.
#
# Defaults:
#   127.0.0.1     — localhost (Prometheus running on the same host)
#   ::1           — IPv6 loopback
#   172.16.0.0/12 — Docker internal bridge subnet (all default Compose networks)
#
# Examples of extending this list:
#   Add a specific Prometheus server:   PROMETHEUS_ALLOWED_IPS=127.0.0.1,::1,172.16.0.0/12,10.0.1.50
#   Add a monitoring VLAN subnet:       PROMETHEUS_ALLOWED_IPS=127.0.0.1,::1,172.16.0.0/12,10.10.0.0/24
#
# Note: the backend validates this list at startup. A malformed entry will abort startup
# with a clear error message rather than silently allowing all traffic.
PROMETHEUS_ALLOWED_IPS=127.0.0.1,::1,172.16.0.0/12
